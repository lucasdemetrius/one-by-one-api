# ═══════════════════════════════════════════════
# OneByOne API — Perfil de DESENVOLVIMENTO (.env.dev)
# Equivalente ao application-dev.yml do Spring: usado no `go run` local e no
# docker-compose.yml (dev). Para PRODUÇÃO use o perfil .env (../.env.example, AMBIENTE=producao).
# Copie e preencha:
#   cp .env.dev.example .env.dev
# O .env.dev real (com segredos) NUNCA é versionado.
# ═══════════════════════════════════════════════

# Perfil do ambiente (seletor, como o spring.profiles.active). Em dev: "desenvolvimento".
AMBIENTE=desenvolvimento

# ───────────────────────────────────────────────
# Banco de Dados MySQL
# Local (go run): DB_HOST=localhost
# Dentro do Docker Compose o host é sobrescrito para 'mysql'.
# ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=oneaone_user
DB_PASSWORD=oneaone_pass_2025
DB_NAME=onebyone

# ───────────────────────────────────────────────
# Autenticação JWT
# JWT_SECRET: chave secreta para assinar os tokens (use um valor longo e aleatório)
# JWT_EXPIRACAO_HORAS: validade do token em horas (padrão 24)
# ───────────────────────────────────────────────
JWT_SECRET=troque-por-uma-chave-secreta-longa-e-aleatoria
JWT_EXPIRACAO_HORAS=24

# ───────────────────────────────────────────────
# Servidor HTTP
# ───────────────────────────────────────────────
PORTA_API=8080

# ───────────────────────────────────────────────
# AWS S3 — Armazenamento privado das fotos
# ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=controleazul
AWS_PREFIXO=one-by-one

# ───────────────────────────────────────────────
# E-mail (SMTP) — OPCIONAL. Vazio = e-mails desligados (dormente).
# Liga 3 e-mails: boas-vindas (cadastro), convite ao liderado e lembretes de 1:1.
# Ex.: AWS SES (SMTP). Preencher HOST + REMETENTE já habilita o envio.
# SMTP_HOST: ex. email-smtp.us-east-1.amazonaws.com
# SMTP_REMETENTE: e-mail "De" (precisa ser verificado no provedor)
# APP_URL: URL pública do app (vai nos links dos e-mails; padrão localhost)
# ───────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_REMETENTE=
# URL pública do app (usada nos links dos e-mails)
APP_URL=http://localhost:3100

# ───────────────────────────────────────────────
# reCAPTCHA (anti-bot) — OPCIONAL. Vazio = DESLIGADO (dormente).
# Quando você tiver as chaves do Google reCAPTCHA (https://www.google.com/recaptcha/admin),
# preencha as duas abaixo: o app passa a exigir a verificação no login/cadastro/recuperação.
#   RECAPTCHA_SITE_KEY  = chave do site (pública, vai pro front)
#   RECAPTCHA_SECRET    = chave secreta (fica só no servidor)
#
# DICA — para TESTAR sem registrar um site, use as chaves de TESTE oficiais do Google
# (sempre passam, o widget mostra "for testing purposes only" — NUNCA em produção):
#   RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MdrnG_3
#   RECAPTCHA_SECRET=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
# ───────────────────────────────────────────────
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# ───────────────────────────────────────────────
# ADMIN da plataforma (super-usuário global de monitoração) — OPCIONAL.
# A conta com ADMIN_EMAIL é garantida como ADMIN no boot:
#   • se a conta JÁ existe  → é promovida a ADMIN (nada mais a fazer).
#   • se NÃO existe e ADMIN_SENHA está preenchida → a conta é CRIADA como ADMIN.
#   • se NÃO existe e ADMIN_SENHA vazia → nada é criado (sem senha padrão, por segurança).
# Requer a migration 023 aplicada. Acesse depois /api/v1/admin/* logando com essa conta.
# ───────────────────────────────────────────────
ADMIN_EMAIL=admin@admin.com.br
ADMIN_SENHA=

# ───────────────────────────────────────────────
# IA de PLATAFORMA (Central de Ajuda) — OPCIONAL. Vazio = desligada.
# Quando preenchida, o assistente da Ajuda responde a QUALQUER usuário (gestor, RH,
# liderado) usando esta chave. Sem ela, a Ajuda usa a IA BYOK do próprio gestor (se houver)
# e, na falta de tudo, mostra só o conteúdo curado. NÃO é a IA por gestor (essa fica no perfil).
#   IA_PLATAFORMA_PROVEDOR = CLAUDE | OPENAI | DEEPSEEK | GROK
#   IA_PLATAFORMA_CHAVE    = a chave de API do provedor escolhido
# ───────────────────────────────────────────────
IA_PLATAFORMA_PROVEDOR=
IA_PLATAFORMA_CHAVE=
