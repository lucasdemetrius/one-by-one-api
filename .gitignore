# Ambiente e segredos (perfis dev/prod) — NUNCA commitar. Só os *.example vão pro git.
.env
.env.*
!*.example
*.env.local

# Binários compilados
/bin/
*.exe
*.out

# Diretório de build do Swagger (gerado via: swag init).
# IMPORTANTE: o docs/docs.go é VERSIONADO de propósito — o cmd/api/rotas.go importa o pacote
# `onebyone-api/docs`, então sem esse arquivo o build em outra máquina (ex.: no Docker do
# servidor) quebra com "package onebyone-api/docs is not in std". Os specs .json/.yaml não
# são necessários para o build, então seguem ignorados.
/docs/swagger.json
/docs/swagger.yaml

# Dependências Go (go.sum é commitado, vendor não é necessário)
/vendor/

# IDE e sistema operacional
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log

# Cobertura de testes
coverage.out
coverage.html
